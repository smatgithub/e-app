{
  "name": "e-food-center",
  "private": true,
  "version": "0.0.1",
  "description": "e-Food Center monorepo — mobile, admin, API",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @efood/api",
    "dev:admin": "npm run dev -w @efood/admin",
    "dev:mobile": "npm run start -w @efood/mobile",
    "build:api": "npm run build -w @efood/api",
    "build:admin": "npm run build -w @efood/admin",
    "build:shared": "npm run build -w @efood/shared",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
